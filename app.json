{
  "expo": {
    "name": "Virtual Empire",
    "slug": "virtual-empire",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0D0D0D"
    },
    "androidStatusBar": {
      "backgroundColor": "#0D0D0D",
      "barStyle": "light-content"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.virtualempire"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0D0D",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "android": {
            "backgroundColor": "#0D0D0D",
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200,
            "resizeMode": "contain"
          }
        }
      ],
      "expo-web-browser",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "df3e7173-cf78-4056-8e07-6e3a3150fec6"
      }
    }
  }
}
